# k6 Performance Framework – .gitignore

# ── Secrets ────────────────────────────────────
.env

# ── Build output ───────────────────────────────
dist/

# ── Node modules ───────────────────────────────
node_modules/

# ── k6 temp files ──────────────────────────────
.k6-temp/
.k6-perf-entry-*.js

# ── Test results ───────────────────────────────
**/results/**/*.json
**/results/**/*.csv
**/results/**/*.html

# ── OS / Editor ────────────────────────────────
.DS_Store
Thumbs.db
.vscode/settings.json
