# .env template — copy to .env and fill in values
# NEVER commit .env to source control

# ── Target Environment ─────────────────────────
K6_BASE_URL=https://your-dev-environment.com

# ── Auth / API Keys ────────────────────────────
K6_API_KEY=your-api-key-here

# -- Framework Settings -------------------------
K6_DEBUG=false

# -- Reporting & InfluxDB Setup -----------------
# Directory to automatically generate timestamped HTML/JSON run reports
K6_RESULTS_BASE_DIR=./scrum-suites/results

# Uncomment and set to stream metrics natively to a local or remote InfluxDB instance (Option A for PowerBI/Grafana)
# K6_INFLUXDB_URL=http://localhost:8086/k6
